{
  "version": 1,
  "blocks": [
    {
      "type": "mqtt_subscribe",
      "label": "MQTT Subscribe",
      "icon": "\ud83d\udce1",
      "category": "input",
      "description": "Subscribe to MQTT channels for real-time data",
      "configSchema": [
        { "key": "channels", "type": "multi-text", "label": "Channels", "placeholder": "sensor-room-a, sensor-room-b", "help": "Comma-separated channel names" },
        { "key": "format", "type": "select", "label": "Format", "options": ["json", "binary", "text"], "default": "json" },
        { "key": "qos", "type": "number", "label": "QoS", "min": 0, "max": 2, "default": 0 }
      ],
      "inputs": [],
      "outputs": [{ "name": "data", "type": "message" }],
      "color": "#0891b2"
    },
    {
      "type": "data_source",
      "label": "Data Source",
      "icon": "\ud83d\udcbe",
      "category": "input",
      "description": "Load data from a database table",
      "configSchema": [
        { "key": "table", "type": "table-select", "label": "Table" },
        { "key": "limit", "type": "number", "label": "Max Rows", "default": 100, "min": 1, "max": 10000 },
        { "key": "order_by", "type": "text", "label": "Order By" },
        { "key": "order_dir", "type": "select", "label": "Direction", "options": ["DESC", "ASC"], "default": "DESC" }
      ],
      "inputs": [],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#0070f3"
    },
    {
      "type": "filter",
      "label": "Filter",
      "icon": "\ud83d\udd0d",
      "category": "transform",
      "description": "Filter rows by condition",
      "configSchema": [
        { "key": "column", "type": "text", "label": "Column" },
        { "key": "operator", "type": "select", "label": "Operator", "options": ["==", "!=", ">", "<", ">=", "<=", "contains", "is null", "is not null"] },
        { "key": "value", "type": "text", "label": "Value" }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#7c3aed"
    },
    {
      "type": "transform",
      "label": "Transform",
      "icon": "\u2699",
      "category": "transform",
      "description": "Transform column values",
      "configSchema": [
        { "key": "column", "type": "text", "label": "Column" },
        { "key": "operation", "type": "select", "label": "Operation", "options": ["round", "abs", "uppercase", "lowercase", "multiply", "add", "to_number", "to_date"] },
        { "key": "param", "type": "text", "label": "Parameter" }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#059669"
    },
    {
      "type": "aggregate",
      "label": "Aggregate",
      "icon": "\ud83d\udcca",
      "category": "transform",
      "description": "Group and aggregate data",
      "configSchema": [
        { "key": "group_by", "type": "text", "label": "Group By" },
        { "key": "agg_column", "type": "text", "label": "Aggregate Column" },
        { "key": "agg_func", "type": "select", "label": "Function", "options": ["count", "sum", "avg", "min", "max"] }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#d97706"
    },
    {
      "type": "fft",
      "label": "FFT Analysis",
      "icon": "\ud83d\udd0a",
      "category": "analysis",
      "description": "Extract frequency components using Fast Fourier Transform",
      "configSchema": [
        { "key": "column", "type": "text", "label": "Signal Column" },
        { "key": "sample_rate", "type": "number", "label": "Sample Rate (Hz)", "default": 1, "min": 0.01 }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#6d28d9"
    },
    {
      "type": "moving_average",
      "label": "Moving Average",
      "icon": "\ud83d\udcc8",
      "category": "analysis",
      "description": "Apply moving average smoothing",
      "configSchema": [
        { "key": "column", "type": "text", "label": "Column" },
        { "key": "window", "type": "number", "label": "Window (seconds)", "default": 10, "min": 1 }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }],
      "color": "#0d9488"
    },
    {
      "type": "anomaly_detection",
      "label": "Anomaly Detect",
      "icon": "\u26a0",
      "category": "analysis",
      "description": "Detect anomalies using statistical methods",
      "configSchema": [
        { "key": "column", "type": "text", "label": "Column" },
        { "key": "method", "type": "select", "label": "Method", "options": ["zscore", "iqr", "rolling_std"], "default": "zscore" },
        { "key": "threshold", "type": "number", "label": "Threshold", "default": 2.0, "min": 0.1 }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [{ "name": "data", "type": "dataset" }, { "name": "anomalies", "type": "dataset" }],
      "color": "#b91c1c"
    },
    {
      "type": "insert",
      "label": "Insert to DB",
      "icon": "\ud83d\udce5",
      "category": "output",
      "description": "Store data to ClickHouse table",
      "configSchema": [
        { "key": "table", "type": "table-select", "label": "Table" },
        { "key": "mapping", "type": "text", "label": "Column Mapping (JSON)", "placeholder": "{\"temp\": \"temperature\"}", "help": "Map payload fields to table columns. Leave empty for auto-match." }
      ],
      "inputs": [{ "name": "data", "type": "any" }],
      "outputs": [],
      "color": "#16a34a"
    },
    {
      "type": "ws_publish",
      "label": "WS Broadcast",
      "icon": "\ud83d\udce2",
      "category": "output",
      "description": "Broadcast data to WebSocket channels",
      "configSchema": [
        { "key": "channels", "type": "multi-text", "label": "Channels", "placeholder": "sensor-room-a, sensor-room-b" }
      ],
      "inputs": [{ "name": "data", "type": "any" }],
      "outputs": [],
      "color": "#ea580c"
    },
    {
      "type": "mqtt_publish",
      "label": "MQTT Publish",
      "icon": "\ud83d\udce4",
      "category": "output",
      "description": "Publish data to MQTT topic",
      "configSchema": [
        { "key": "topic", "type": "text", "label": "Topic" },
        { "key": "qos", "type": "number", "label": "QoS", "default": 0, "min": 0, "max": 2 }
      ],
      "inputs": [{ "name": "data", "type": "any" }],
      "outputs": [],
      "color": "#0891b2"
    },
    {
      "type": "chart",
      "label": "Chart Output",
      "icon": "\ud83d\udcc8",
      "category": "output",
      "description": "Render data as a chart",
      "configSchema": [
        { "key": "chart_type", "type": "select", "label": "Chart Type", "options": ["bar", "line", "pie"] },
        { "key": "x_column", "type": "text", "label": "X Axis" },
        { "key": "y_column", "type": "text", "label": "Y Axis" },
        { "key": "title", "type": "text", "label": "Title" }
      ],
      "inputs": [{ "name": "data", "type": "dataset" }],
      "outputs": [],
      "color": "#dc2626"
    },
    {
      "type": "custom_code",
      "label": "Custom Code",
      "icon": "\ud83d\udcbb",
      "category": "custom",
      "description": "Run custom Python code. Define transform(data, config) function.",
      "configSchema": [
        { "key": "code", "type": "code", "label": "Python Code", "language": "python", "default": "def transform(data, config):\n    # data = upstream output\n    # return processed data\n    return data" },
        { "key": "params", "type": "text", "label": "Custom Parameters (JSON)", "default": "{}" }
      ],
      "inputs": [{ "name": "data", "type": "any" }],
      "outputs": [{ "name": "data", "type": "any" }],
      "color": "#374151"
    },
    {
      "type": "notify",
      "label": "Notify",
      "icon": "\ud83d\udd14",
      "category": "output",
      "description": "Send notification to users",
      "configSchema": [
        { "key": "title", "type": "text", "label": "Title" },
        { "key": "message", "type": "text", "label": "Message" },
        { "key": "type", "type": "select", "label": "Type", "options": ["info", "warning", "error"], "default": "info" }
      ],
      "inputs": [{ "name": "data", "type": "any" }],
      "outputs": [],
      "color": "#ec4899"
    }
  ],
  "configTypes": {
    "text": { "component": "input", "inputType": "text" },
    "number": { "component": "input", "inputType": "number" },
    "select": { "component": "select" },
    "multi-text": { "component": "input", "inputType": "text", "help": "Comma-separated values" },
    "table-select": { "component": "select", "source": "tables" },
    "channel-select": { "component": "select", "source": "channels" },
    "code": { "component": "textarea", "rows": 10, "monospace": true },
    "toggle": { "component": "checkbox" }
  },
  "categories": [
    { "id": "input", "label": "Input", "icon": "\ud83d\udce5" },
    { "id": "transform", "label": "Transform", "icon": "\ud83d\udd04" },
    { "id": "analysis", "label": "Analysis", "icon": "\ud83d\udcca" },
    { "id": "output", "label": "Output", "icon": "\ud83d\udce4" },
    { "id": "custom", "label": "Custom", "icon": "\ud83e\udde9" }
  ]
}
